global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "node_exporter"
    static_configs:
{% for host in groups['all'] %}
{% if host != 'localhost' %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:9100"
        labels:
          hostname: "{{ host }}"
{% endif %}
{% endfor %}
